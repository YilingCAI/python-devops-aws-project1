# ==============================================================================
# Application Configuration - Environment Variables Template
# ==============================================================================
# This is a template file. Copy appropriate version for your environment:
# - Local Development:  .env.local (from .env.local.example)
# - Docker Development: .env.docker (from .env.docker.example)  
# - Staging:           .env.staging (from AWS Secrets Manager)
# - Production:        .env.prod (from AWS Secrets Manager)
#
# NEVER commit actual .env files to git - use Secrets Manager for production
# ==============================================================================

# ============================================================================
# ENVIRONMENT & APPLICATION
# ============================================================================
ENVIRONMENT=development
PROJECT_NAME=myproject
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ============================================================================
# BACKEND - FASTAPI SERVER
# ============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=false
BACKEND_WORKERS=4
API_TITLE=MyProject API
API_DESCRIPTION=Production-ready full-stack application
API_VERSION=1.0.0

# ============================================================================
# DATABASE - PostgreSQL
# ============================================================================
DATABASE_USER=postgres
DATABASE_PASSWORD=changeme_in_production
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=myproject
# Connection pool settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false

# ============================================================================
# SECURITY - JWT & Sessions
# ============================================================================
JWT_SECRET_KEY=changeme_in_production_with_strong_random_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# ============================================================================
# SECURITY - CORS & Origins
# ============================================================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=Content-Type,Authorization

# ============================================================================
# SECURITY - Headers & Security
# ============================================================================
ENABLE_HTTPS_REDIRECT=false
ENABLE_HSTS=true
HSTS_MAX_AGE=31536000
SECURE_COOKIES=false

# ============================================================================
# FRONTEND
# ============================================================================
FRONTEND_URL=http://localhost:4200
API_BASE_URL=http://localhost:8000

# ============================================================================
# LOGGING
# ============================================================================
LOG_FORMAT=json
LOG_OUTPUT=console
LOG_FILE_PATH=/var/log/app
LOG_FILE_MAX_BYTES=10485760
LOG_FILE_BACKUP_COUNT=10

# ============================================================================
# AWS - Production only (leave empty for local development)
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SECRETS_MANAGER_SECRET_NAME=myproject/prod

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================
SENTRY_DSN=
DATADOG_API_KEY=
ENABLE_METRICS=true
METRICS_PORT=9090

# ============================================================================
# EMAIL NOTIFICATIONS (Optional)
# ============================================================================
SMTP_SERVER=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@myproject.com

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
