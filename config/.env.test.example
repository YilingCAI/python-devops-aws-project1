# ==============================================================================
# Test Environment Configuration - Example Template
# ==============================================================================
# Copy this to .env.test and configure for your test database
# NEVER commit .env.test to git
# ==============================================================================

ENVIRONMENT=test
PROJECT_NAME=myproject
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Backend Server - Not used in tests
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=false
BACKEND_WORKERS=1
API_TITLE=MyProject API
API_DESCRIPTION=Test Environment
API_VERSION=1.0.0

# Database - Test PostgreSQL (auto-rollback on each test)
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=test_myproject
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false

# Security - Test Keys (MUST NOT be used in production)
JWT_SECRET_KEY=test-secret-key-do-not-use-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# CORS - Allow test clients
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=Content-Type,Authorization

# Security Headers - Disabled for tests
ENABLE_HTTPS_REDIRECT=false
ENABLE_HSTS=false
SECURE_COOKIES=false

# Frontend - Not used in tests
FRONTEND_URL=http://localhost:8000
API_BASE_URL=http://localhost:8000

# Logging - Minimal output for tests
LOG_FORMAT=json
LOG_OUTPUT=console
LOG_LEVEL=WARNING

# AWS - Not needed for tests
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Monitoring - Disabled for tests
SENTRY_DSN=
DATADOG_API_KEY=
ENABLE_METRICS=false

# Rate Limiting - Disabled for tests
RATE_LIMIT_ENABLED=false
