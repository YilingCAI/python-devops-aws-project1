# ==============================================================================
# Terraform Variables Example
# Copy to: ../mypythonproject1-infra/environments/{env}/terraform.tfvars
# ==============================================================================

# ============================================================================
# Environment
# ============================================================================
environment = "staging"
aws_region  = "us-east-1"

# ============================================================================
# VPC & Networking
# ============================================================================
vpc_cidr              = "10.0.0.0/16"
availability_zones    = ["us-east-1a", "us-east-1b"]
private_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
public_subnet_cidrs   = ["10.0.101.0/24", "10.0.102.0/24"]

# ============================================================================
# RDS Database
# ============================================================================
db_engine              = "postgres"
db_engine_version      = "16.1"
db_instance_class      = "db.t4g.micro"  # t4g.small for production
db_allocated_storage   = 20
db_name                = "myproject"
db_username            = "postgres"
# db_password is injected via AWS Secrets Manager at runtime
backup_retention_days  = 7
multi_az              = false  # true for production

# ============================================================================
# ECS Cluster
# ============================================================================
ecs_cluster_name       = "myproject-staging"
ecs_container_port     = 8000
ecs_desired_count      = 2
ecs_min_capacity       = 1
ecs_max_capacity       = 4
ecs_cpu                = "256"   # 512 for production
ecs_memory             = "512"   # 1024 for production

# ============================================================================
# Application Secrets (Stored in AWS Secrets Manager)
# ============================================================================
# NOTE: These are NOT hardcoded here. Instead:
# 1. Secrets are created in AWS Secrets Manager manually or via bootstrap
# 2. Terraform references them via aws_secretsmanager_secret data source
# 3. ECS task definition injects them as environment variables
# 4. Application reads them from environment at runtime

# Example: Application needs these secrets (created separately):
# - /myproject/staging/db-password
# - /myproject/staging/jwt-secret
# - /myproject/staging/api-keys
# - /myproject/staging/third-party-credentials

# ============================================================================
# Tags
# ============================================================================
tags = {
  Project       = "myproject"
  Environment   = "staging"
  ManagedBy     = "Terraform"
  CreatedAt     = "2026-02-18"
  CostCenter    = "engineering"
}

# ============================================================================
# Feature Flags
# ============================================================================
enable_nat_gateway = true
enable_vpn_gateway = false
enable_monitoring  = true
