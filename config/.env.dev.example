# ==============================================================================
# Development Environment Configuration - Example Template
# ==============================================================================
# Copy this to .env.dev and configure for your development database
# NEVER commit .env.dev to git
# ==============================================================================

ENVIRONMENT=development
PROJECT_NAME=myproject
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=DEBUG

# Backend Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
BACKEND_WORKERS=1
API_TITLE=MyProject API
API_DESCRIPTION=Development Environment
API_VERSION=1.0.0

# Database - Local PostgreSQL
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=myproject_dev
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=true

# Security - Dev Keys (USE ONLY IN LOCAL DEV)
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# CORS - Local Development
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000,http://127.0.0.1:4200
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=Content-Type,Authorization

# Security Headers - Disabled for local dev
ENABLE_HTTPS_REDIRECT=false
ENABLE_HSTS=false
SECURE_COOKIES=false

# Frontend
FRONTEND_URL=http://localhost:4200
API_BASE_URL=http://localhost:8000

# Logging - Console output for development
LOG_FORMAT=text
LOG_OUTPUT=console
LOG_LEVEL=DEBUG

# AWS - Not needed for local dev
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Monitoring - Disabled for local dev
SENTRY_DSN=
DATADOG_API_KEY=
ENABLE_METRICS=false

# Rate Limiting - Relaxed for development
RATE_LIMIT_ENABLED=false
